#lang racket/base

(require "./util.rkt")

(provide point
         vector
         primitive-x
         primitive-y
         primitive-z
         primitive-w
         primitive-eq?
         point?
         vector?
         primitive-add
         primitive-sub
         primitive-scale
         primitive-dot
         primitive-cross
         primitive-magnitude
         primitive-normalize
         )

(define (point x y z)
  (list x y z 1))

(define (vector x y z)
  (list x y z 0))

(define (primitive-x v) (car v))
(define (primitive-y v) (cadr v))
(define (primitive-z v) (caddr v))
(define (primitive-w v) (cadddr v))
(define (primitive-eq? a b)
  (and
    (rough-eq? (primitive-x a) (primitive-x b))
    (rough-eq? (primitive-y a) (primitive-y b))
    (rough-eq? (primitive-z a) (primitive-z b))
    (rough-eq? (primitive-w a) (primitive-w b))))

(define (point? p) (eq? (primitive-w p) 1.0))
(define (vector? p) (eq? (primitive-w p) 0.0))

(define (primitive-add a b)
  (map + a b))

(define (primitive-sub a b)
  (map - a b))

(define (primitive-scale s p)
  (map (lambda (x) (* x s)) p))

(define (primitive-dot a b)
  (foldr + 0 (map * a b)))

(define (primitive-cross) 0)

(define (primitive-magnitude p)
  (sqrt (foldr + 0 (map * p p))))

(define (primitive-normalize p)
  (let ([m (primitive-magnitude p)])
    (primitive-scale (/ 1 m) p)))

